@model ShopCartVM
@{
    var AvailableInputColor = "bg-success text-light";
    if (Model.AvailableQty <= Model.ShopCart.Variant.LowStockWarningQuantity)
    {
        AvailableInputColor = "bg-danger text-light";
    }
}
<input asp-for="ShopCart.Variant.Id" hidden />
<input asp-for="ShopCart.VariantId" hidden />
<div class="input-group mb-1">
    <div class="input-group-prepend col-6">
        <label asp-for="ShopCart.Variant.ListPrice" class="input-group-text"></label>
    </div>
    <input asp-for="ShopCart.Variant.ListPrice" class="form-control" />
    <span asp-validation-for="ShopCart.Variant.ListPrice" class="text-danger"></span>
</div>
<div class="input-group mb-1">
    <div class="input-group-prepend col-6">
        <label asp-for="ShopCart.Variant.WholesalePrice" class="input-group-text"></label>
    </div>
    <input asp-for="ShopCart.Variant.WholesalePrice" class="form-control" />
    <span asp-validation-for="ShopCart.Variant.WholesalePrice" class="text-danger"></span>
</div>
<div class="input-group mb-1">
    <div class="input-group-prepend col-6">
        <label asp-for="ShopCart.Variant.Size" class="input-group-text"></label>
    </div>
    <input asp-for="ShopCart.Variant.Size" readonly class="form-control" />
    <span asp-validation-for="ShopCart.Variant.Size" class="text-danger"></span>
</div>
<div class="input-group mb-1">
    <div class="input-group-prepend col-6">
        <label asp-for="ShopCart.UnitOfMeasure" class="input-group-text"></label>
    </div>
    <Select asp-for="ShopCart.UnitOfMeasureId" asp-items="@Model.UnitOfMeasureList" class="form-select">
    </Select>
    <span asp-validation-for="ShopCart.UnitOfMeasureId" class="text-danger"></span>
</div>
<div class="input-group mb-1">
    <div class="input-group-prepend col-6">
        <label asp-for="ShopCart.Discount" class="input-group-text"></label>
    </div>
    <input asp-for="ShopCart.Discount" class="form-control" />
    <span asp-validation-for="ShopCart.Discount" class="text-danger"></span>
</div>

<div class="mb-1 row">
    <div class="input-group-prepend col-7">
        <div class="input-group-text">
            <label asp-for="IsReturn"></label>
        </div>
    </div>
    <div class="col-5">
        <input asp-for="IsReturn" class="form-check-input" />
    </div>
</div>
<div class="input-group mb-1">
    <div class="input-group-prepend  col-6">
        <label asp-for="AvailableQty" class="input-group-text"></label>
    </div>
    <input asp-for="AvailableQty" readonly class="form-control @AvailableInputColor" />
    <span asp-validation-for="AvailableQty" class="text-danger"></span>
</div>
